rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isFriend(uid) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(uid));
    }

    function validUserCreate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.nickname is string
        && (
          request.resource.data.photoUrl == null ||
          request.resource.data.photoUrl is string
        )
        && request.resource.data.avatarPath == null
        && request.resource.data.isBanned == false
        && request.resource.data.stats.pointsTotal == 0
        && request.resource.data.stats.guessesCount == 0
        && request.resource.data.stats.postsCount == 0
        && request.resource.data.stats.friendsCount == 0
        && request.resource.data.stats.bestGuessMeters == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.lastLoginAt == request.time;
    }

    function validUserSelfUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "lastLoginAt",
            "updatedAt",
            "photoUrl",
            "avatarPath",
            "stats"
          ])
        && request.resource.data.updatedAt == request.time
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(["lastLoginAt"]) ||
          request.resource.data.lastLoginAt == request.time
        )
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(["photoUrl"]) ||
          request.resource.data.photoUrl is string
        )
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(["avatarPath"]) ||
          request.resource.data.avatarPath.matches("^avatars/" + request.auth.uid + "/profile_[0-9]+\\.jpg$")
        );
    }

    function validPostCreate() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.user is string
        && request.resource.data.imageUrl is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        && request.resource.data.isActive == true
        && request.resource.data.createdAt == request.time
        && (
          !("authorPhotoUrl" in request.resource.data) ||
          request.resource.data.authorPhotoUrl == null ||
          request.resource.data.authorPhotoUrl is string
        )
        && (
          !("gameMode" in request.resource.data) ||
          request.resource.data.gameMode == "CITY"
        );
    }
    function hasGuessedPost(postId) {
      return signedIn()
        && exists(/databases/$(database)/documents/guesses/$(request.auth.uid + "_" + postId));
    }

    match /users/{uid} {
      // Wymagane przez:
      // - getUsersForFriendSearch()
      // - getFriends()
      // - getUserProfile()
      allow get, list: if signedIn();

      // Wymagane przez createUserIfNotExists()
      allow create: if validUserCreate(uid);

      // Wymagane przez:
      // - login update lastLoginAt
      // - updateProfilePicture()
      allow update: if isSelf(uid) && validUserSelfUpdate();

      allow delete: if false;

      match /friends/{friendUid} {
        // Wymagane przez getFriendUids() i getFriends()
        allow read: if isSelf(uid);

        // Tworzenie/usuwanie znajomych tylko przez Cloud Functions.
        allow create, update, delete: if false;
      }
    }

    match /posts/{postId} {
      // Pojedynczy post:
      // - własny,
      // - znajomego,
      // - wcześniej zgadnięty.
      allow get: if signedIn()
        && (
          hasGuessedPost(postId) ||
          resource.data.userId == request.auth.uid ||
          isFriend(resource.data.userId)
        );

      // Zapytania kolekcji:
      // - własne posty,
      // - posty znajomych.
      allow list: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          isFriend(resource.data.userId)
        );

      allow create: if validPostCreate();

      allow update: if false;

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }


    match /friendRequests/{requestId} {
      // Wymagane przez getIncomingRequests() i getOutgoingRequests().
      allow get, list: if signedIn()
        && (
          resource.data.fromUid == request.auth.uid ||
          resource.data.toUid == request.auth.uid
        );

      // Wysyłanie/akceptacja/odrzucanie/usuwanie przez Cloud Functions.
      allow create, update, delete: if false;
    }

    match /guesses/{guessId} {
      // getMyGuessForPost() - sprawdza konkretny dokument uid_postId,
      // nawet jeśli dokument jeszcze nie istnieje.
      allow get: if signedIn()
        && guessId.matches("^" + request.auth.uid + "_.*");

      // getMyGuessedPosts() / getMyGuessedPostIds()
      // pozwala pobrać tylko własne zgadnięcia.
      allow list: if signedIn()
        && resource.data.userUid == request.auth.uid;

      // Zgadywanie zapisuje tylko Cloud Function submitGuess.
      allow create, update, delete: if false;
    }
		match /{document=**} {
      allow read, write: if false;
    }
  }
}